# RFPRespond — Dev environment template
# Copy to .env.local and fill in your values. DO NOT commit .env.local.

# Microsoft 365 / Teams
TEAMS_APP_ID=
TEAMSFX_ENV=dev

# Entra App Registration (DA client)
AAD_APP_CLIENT_ID=
AAD_APP_TENANT_ID=
AAD_APP_OAUTH_AUTHORITY=https://login.microsoftonline.com/YOUR_TENANT_ID
AAD_APP_OAUTH_AUTHORITY_HOST=https://login.microsoftonline.com/

# MCP Server
MCP_SERVER_URL=https://YOUR_ACA_INGRESS.azurecontainerapps.io
OAUTH_REGISTRATION_ID=

# SharePoint
SHAREPOINT_TENANT=YOUR_TENANT_NAME
SHAREPOINT_SITE=RFPCorpus
